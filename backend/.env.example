# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
DEBUG=false
PUBLIC_BASE_URL=https://your-backend.onrender.com

# ── Secrets (generate: python -c "import secrets; print(secrets.token_hex(32))") ──
SERVER_SECRET=CHANGE_ME_32_HEX_BYTES
MASTER_KEY=CHANGE_ME_32_HEX_BYTES
JWT_SECRET=CHANGE_ME_32_HEX_BYTES

# ── Firebase ──────────────────────────────────────────────────────────────────
# base64 -w 0 firebase-credentials.json
FIREBASE_CREDENTIALS=BASE64_ENCODED_SERVICE_ACCOUNT_JSON

# ── Cloudflare Turnstile ─────────────────────────────────────────────────────
# Get from https://dash.cloudflare.com → Turnstile
TURNSTILE_SITE_KEY=your_site_key_here
TURNSTILE_SECRET=your_secret_key_here

# ── Tuning ────────────────────────────────────────────────────────────────────
LOAD_TOKEN_TTL=25
HOOK_RATE_THRESHOLD=20
